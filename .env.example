NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# Server-only. Prefer Application Default Credentials in Firebase App Hosting.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional for local wallet login when using Application Default Credentials.
# Must be a service account email the current ADC can sign with iam.serviceAccounts.signBlob.
FIREBASE_ADMIN_SERVICE_ACCOUNT_ID=

# Server-only. Used by /api/pacstac/sonosig/claims.
PACSTAC_API_KEY=
PACSTAC_SONOSIG_CLAIMS_URL=https://pacstac.com/api/v1/namespaces/sonosig/claims

# Server-only. Used by /api/support/chat when chatbot support is enabled.
OPENAI_API_KEY=
OPENAI_VECTOR_STORE_ID=
OPENAI_SUPPORT_MODEL=gpt-5.4-mini

# Optional MCP/ENS automation. The signing key must control or manage the ENS
# name being updated.
# Preferred Base RPC for x402 wallet balance reads. If missing/unavailable,
# admin wallet status falls back to Base's public RPC at https://mainnet.base.org.
BASE_RPC_URL=
EVM_MULTI_CHAIN_RPC_URL=
# Backward-compatible fallback.
ETHEREUM_RPC_URL=
ENS_SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/ensdomains/ens
SONOSIG_ENS_PRIVATE_KEY=
BASE_X402_WALLET_PRIVATE_KEY=
BASE_X402_WALLET_PUBLIC_KEY=

# Optional 0G Storage receipt mirror. Configure the private key on the server,
# then enable 0G Storage in /admin/api-config.
ZEROG_STORAGE_PRIVATE_KEY=
ZEROG_STORAGE_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZEROG_STORAGE_NETWORK=0G Galileo Testnet
