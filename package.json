{
  "name": "sonosig",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "next dev -p 3050",
    "build": "IS_WEBPACK_TEST=1 next build",
    "start": "next start",
    "lint": "eslint",
    "mcp:stdio": "node scripts/sonosig-mcp-server.mjs",
    "test:mcp": "node scripts/test-mcp-server.mjs",
    "scan:website": "node scripts/scan-sonosig-website.mjs",
    "firebase:emulators": "firebase emulators:start --only auth,firestore,hosting",
    "firebase:deploy": "rm -rf .next .firebase && IS_WEBPACK_TEST=1 firebase deploy --only firestore,hosting",
    "firebase:deploy:rules": "firebase deploy --only firestore",
    "dns:porkbun:check": "node scripts/sync-porkbun-firebase-dns.mjs check",
    "dns:porkbun:sync": "node scripts/sync-porkbun-firebase-dns.mjs sync"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.100.5",
    "@x402/evm": "^2.11.0",
    "@x402/fetch": "^2.11.0",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "next": "16.2.4",
    "opus-recorder": "^8.0.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.48.4",
    "wagmi": "^2.19.5",
    "zod": "^4.3.6"
  },
  "overrides": {
    "axios": "1.15.0",
    "postcss": "8.5.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "firebase-tools": "^15.15.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
